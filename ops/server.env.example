# Copy this file to /etc/tls-pq-bench/server.env on the server host.

# Repo and server binary on the benchmark server host.
REPO_DIR=/home/admin/tls-pq-bench
SERVER_BIN=/home/admin/tls-pq-bench/target/release/server

# Listener and logging configuration.
BIND_HOST=0.0.0.0
LOG_DIR=/home/admin/tls-pq-bench/.logs
LOG_PREFIX=prod-server
BANNER=Starting production benchmark servers on 0.0.0.0:

# Optional certificate pair for verified remote runs.
# Leave both empty for insecure smoke tests with ephemeral certs.
CERT=
KEY=
