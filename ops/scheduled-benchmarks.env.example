# Copy this file to /etc/tls-pq-bench/scheduled.env or another path, then set
# SCHEDULE_ENV_FILE to point at it when running the helper scripts manually.

# Repo and binaries on the runner VPS.
REPO_DIR=/home/admin/tls-pq-bench
RUNNER_BIN=/home/admin/tls-pq-bench/target/release/runner

# Output paths on the runner VPS.
RESULTS_DIR=/home/admin/tls-pq-bench/results/scheduled
LOG_DIR=/home/admin/tls-pq-bench/.logs/scheduled
LOCK_DIR=/home/admin/tls-pq-bench/.locks

# Remote benchmark server address and TLS identity.
SERVER_HOST=10.0.0.10
SERVER_NAME=bench.example.com
CA_CERT=certs/ca.der

# Optional provenance fields included in scheduled run metadata.
RUNNER_INSTANCE_TYPE=
RUNNER_REGION=
RUNNER_AZ=
SERVER_GIT_COMMIT=
SERVER_INSTANCE_TYPE=
SERVER_REGION=
SERVER_AZ=

# Generated benchmark configs on the runner VPS.
TRACK_CONFIG=/home/admin/tls-pq-bench/benchmarks/remote-recurring.toml
FULL_CONFIG=/home/admin/tls-pq-bench/benchmarks/remote-full.toml

# Iteration controls for generated configs.
TRACK_ITERS=200
TRACK_WARMUP=20
FULL_ITERS=200
FULL_WARMUP=20
